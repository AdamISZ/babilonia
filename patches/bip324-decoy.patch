+bool V2Transport::SetDecoyToSend(Span<const uint8_t> contents) noexcept
+{
+    // Babilonia: a decoy is an ordinary v2 packet with the ignore bit set. Same send-buffer
+    // discipline as SetMessageToSend, but the payload is `contents` verbatim (no message-type
+    // encoding) and the cipher's ignore flag is set.
+    AssertLockNotHeld(m_send_mutex);
+    LOCK(m_send_mutex);
+    if (m_send_state == SendState::V1) return false; // v1 has no decoys
+    if (!(m_send_state == SendState::READY && m_send_buffer.empty())) return false;
+    m_send_buffer.resize(contents.size() + BIP324Cipher::EXPANSION);
+    m_cipher.Encrypt(MakeByteSpan(contents), {}, /*ignore=*/true, MakeWritableByteSpan(m_send_buffer));
+    m_send_type = "decoy";
+    return true;
+}
+
+std::vector<std::vector<uint8_t>> V2Transport::GetReceivedDecoys() noexcept
+{
+    AssertLockNotHeld(m_recv_mutex);
+    LOCK(m_recv_mutex);
+    std::vector<std::vector<uint8_t>> out;
+    out.swap(m_recv_decoys);
+    return out;
+}
