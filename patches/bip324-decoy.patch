+bool CConnman::SendDecoy(NodeId id, Span<const uint8_t> payload)
+{
+    // Babilonia: queue the decoy through the normal send path (vSendMsg), flagged as a decoy so
+    // the transport emits it as a BIP324 ignore packet (see SocketSendData / V2Transport).
+    CSerializedNetMsg msg;
+    msg.m_is_decoy = true;
+    msg.data.assign(payload.begin(), payload.end());
+    bool queued = false;
+    ForNode(id, [&](CNode* node) {
+        PushMessage(node, std::move(msg));
+        queued = true;
+        return true;
+    });
+    return queued;
+}
+
+std::vector<std::vector<uint8_t>> CConnman::GetDecoys(NodeId id)
+{
+    std::vector<std::vector<uint8_t>> out;
+    ForNode(id, [&](CNode* node) {
+        out = node->m_transport->GetReceivedDecoys();
+        return true;
+    });
+    return out;
+}
