+static RPCHelpMan senddecoy()
+{
+    return RPCHelpMan{"senddecoy",
+        "\nBabilonia: send a BIP324 v2 decoy packet carrying arbitrary bytes to a connected peer.\n"
+        "The peer decrypts it, sees the ignore bit, and (with the Babilonia patch) surfaces the\n"
+        "payload via getdecoys instead of discarding it. Requires a v2 (BIP324) connection.\n",
+        {
+            {"nodeid", RPCArg::Type::NUM, RPCArg::Optional::NO, "The peer's node id (from getpeerinfo)."},
+            {"payload", RPCArg::Type::STR_HEX, RPCArg::Optional::NO, "Hex-encoded decoy payload."},
+        },
+        RPCResult{RPCResult::Type::BOOL, "", "whether the decoy was queued for sending"},
+        RPCExamples{HelpExampleCli("senddecoy", "0 \"deadbeef\"") + HelpExampleRpc("senddecoy", "0, \"deadbeef\"")},
+    [&](const RPCHelpMan& self, const JSONRPCRequest& request) -> UniValue
+{
+    NodeContext& node = EnsureAnyNodeContext(request.context);
+    CConnman& connman = EnsureConnman(node);
+    const NodeId id{request.params[0].getInt<int64_t>()};
+    const std::vector<unsigned char> payload{ParseHex(request.params[1].get_str())};
+    if (!connman.SendDecoy(id, payload)) {
+        throw JSONRPCError(RPC_MISC_ERROR, "Peer not found or not fully connected");
+    }
+    return true;
+},
+    };
+}
+
+static RPCHelpMan getdecoys()
+{
+    return RPCHelpMan{"getdecoys",
+        "\nBabilonia: drain and return the payloads of BIP324 decoy packets received from a peer.\n",
+        {
+            {"nodeid", RPCArg::Type::NUM, RPCArg::Optional::NO, "The peer's node id (from getpeerinfo)."},
+        },
+        RPCResult{RPCResult::Type::ARR, "", "", {{RPCResult::Type::STR_HEX, "", "a received decoy payload (hex)"}}},
+        RPCExamples{HelpExampleCli("getdecoys", "0") + HelpExampleRpc("getdecoys", "0")},
+    [&](const RPCHelpMan& self, const JSONRPCRequest& request) -> UniValue
+{
+    NodeContext& node = EnsureAnyNodeContext(request.context);
+    CConnman& connman = EnsureConnman(node);
+    const NodeId id{request.params[0].getInt<int64_t>()};
+    UniValue arr(UniValue::VARR);
+    for (const auto& d : connman.GetDecoys(id)) arr.push_back(HexStr(d));
+    return arr;
+},
+    };
+}
